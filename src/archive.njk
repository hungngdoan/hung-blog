---
layout: base.njk
title: "Archive ~ Hung's Journal"
description: "Browse every entry in Hung's Journal, newest first."
navActive: archive.html
permalink: archive.html
pageClass: archive-page
---

<section class="page-section archive-section">
  <div class="section-header">
    <h2>&#128451;&#65039; Journal Archive</h2>
    <span class="section-count">{{ collections.post | length }} POSTS</span>
  </div>
  <p class="archive-intro">Every entry, newest first. Pick a checkpoint and jump back in.</p>

  {% for group in collections.post | reverse | groupPostsByMonth %}
  <section class="archive-month" aria-labelledby="archive-{{ group.key }}">
    <h3 id="archive-{{ group.key }}">{{ group.label }}</h3>
    <ol class="archive-list">
      {% for post in group.posts %}
      <li>
        <time datetime="{{ post.date | isoDate }}">{{ post.data.displayDate }}</time>
        <div>
          <a href="{{ post.url }}">{{ post.data.title }}</a>
          <p>{{ post.data.description }}</p>
        </div>
      </li>
      {% endfor %}
    </ol>
  </section>
  {% endfor %}
</section>

