<section class="page-section rizz-section">
  <div class="rizz-hero">
    <h2>Rizz Lab</h2>
    <p class="rizz-tagline">😏 Smooth lines, cheesy puns &amp; certified dad jokes 😏</p>
    <div class="rizz-legend">
      <span><b>RIZZ</b> = how smooth it lands</span>
      <span><b>🧀</b> = how cheesy it is</span>
      <span>Pull the lever. Steal a line. Use responsibly.</span>
    </div>
  </div>

  <!-- ===== The RIZZ-O-MATIC ===== -->
  <div class="rizz-machine" data-machine>
    <div class="rizz-machine-top">
      <span class="rizz-light" aria-hidden="true"></span>
      RIZZ-O-MATIC 3000
      <span class="rizz-light" aria-hidden="true"></span>
    </div>

    <div class="rizz-screen">
      <span class="rizz-screen-cat" data-machine-cat>READY</span>
      <p class="rizz-screen-line" data-machine-line>Pull the lever for your first line...</p>
    </div>

    <div class="rizz-meter">
      <div class="rizz-meter-label">
        <span>SMOOTHNESS</span>
        <b><span data-machine-score>--</span></b>
      </div>
      <div class="rizz-meter-track">
        <div class="rizz-meter-fill" data-machine-fill></div>
      </div>
    </div>

    <div class="rizz-machine-controls">
      <button type="button" class="rizz-btn rizz-btn-pull" data-machine-pull>
        🎰 PULL A LINE
      </button>
      <button type="button" class="rizz-btn" data-machine-copy>
        📋 STEAL IT
      </button>
    </div>

    <div class="rizz-machine-foot">
      <span>LINES PULLED: <b data-machine-count>0</b></span>
      <span>{{ lines | length }} lines loaded</span>
    </div>
  </div>

  <!-- ===== The line-up ===== -->
  <h2>The Line-Up</h2>

  <div class="rizz-tools">
    <div class="rizz-filters" role="group" aria-label="Filter lines by type">
      <button type="button" class="rizz-chip is-active" data-filter="all">All</button>
      <button type="button" class="rizz-chip" data-filter="Flirty">Flirty</button>
      <button type="button" class="rizz-chip" data-filter="Pun">Pun</button>
      <button type="button" class="rizz-chip" data-filter="Dad Joke">Dad Joke</button>
      <button type="button" class="rizz-chip" data-filter="Nerdy">Nerdy</button>
    </div>
    <input
      class="rizz-search"
      id="rizzSearch"
      type="search"
      autocomplete="off"
      placeholder="Search lines..."
      aria-label="Search lines"
    />
    <div class="rizz-count" data-count></div>
  </div>

  <p class="rizz-empty" data-empty>No lines match. Tough crowd. 🦗</p>

  <div class="rizz-grid" data-grid>
    {% for line in lines %}
    <article class="rizz-card" data-cat="{{ line.cat }}" data-rizz="{{ line.rizz }}">
      <div class="rizz-card-top">
        <span class="rizz-card-emoji" aria-hidden="true">{{ line.emoji }}</span>
        <span class="rizz-tag">{{ line.cat }}</span>
      </div>
      <p class="rizz-card-line">{{ line.text }}</p>
      <div class="rizz-card-meters">
        <div class="rizz-cheese" title="Cheese factor: {{ line.cheese }} of 5">
          <span class="rizz-cheese-label">Cheese</span>
          {%- for i in range(0, 5) -%}
            <span{% if i >= line.cheese %} class="rizz-cheese-empty"{% endif %} aria-hidden="true">🧀</span>
          {%- endfor -%}
        </div>
        <div class="rizz-card-rizz">
          <span>RIZZ {{ line.rizz }}</span>
          <div class="rizz-mini-track" aria-hidden="true">
            <div class="rizz-mini-fill" style="width: {{ line.rizz }}%"></div>
          </div>
        </div>
      </div>
      <button type="button" class="rizz-card-copy">📋 Steal</button>
    </article>
    {% endfor %}
  </div>

  {# Source for the random-post die: on this page the die deals a random line
     card. Inert marker that points at the live cards; no visible output. #}
  <div
    data-rp-source
    data-rp-title="A WILD LINE APPEARED!"
    data-rp-entries=".rizz-section .rizz-card"
    hidden
  ></div>

  <div class="rizz-toast" data-toast role="status" aria-live="polite"></div>
</section>

<script>
(function () {
  "use strict";

  var section = document.querySelector(".rizz-section");
  if (!section) return;

  var cards = Array.prototype.slice.call(section.querySelectorAll(".rizz-card"));
  if (!cards.length) return;

  var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  /* ---------- toast + clipboard (shared) ---------- */
  var toastTimer = null;

  function showToast(msg) {
    var toast = document.querySelector(".rizz-toast");
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.remove("is-show");
    void toast.offsetWidth; // restart the entrance transition
    toast.classList.add("is-show");
    clearTimeout(toastTimer);
    toastTimer = setTimeout(function () {
      toast.classList.remove("is-show");
    }, 1900);
  }

  function copyText(text) {
    function done() { showToast("Stolen! Now go get 'em 💘"); }
    function fallback() {
      var ta = document.createElement("textarea");
      ta.value = text;
      ta.setAttribute("readonly", "");
      ta.style.position = "absolute";
      ta.style.left = "-9999px";
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand("copy"); done(); }
      catch (e) { showToast("Couldn't copy — grab it manually 🙈"); }
      document.body.removeChild(ta);
    }
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text).then(done, fallback);
    } else {
      fallback();
    }
  }

  // Delegate card "Steal" clicks once at the document level so it also works
  // for cards cloned into the random-post popup. Guarded so PJAX re-runs of
  // this script don't stack duplicate listeners.
  if (!window.__rizzCopyBound) {
    window.__rizzCopyBound = true;
    document.addEventListener("click", function (e) {
      var btn = e.target.closest && e.target.closest(".rizz-card-copy");
      if (!btn) return;
      var card = btn.closest(".rizz-card");
      var lineEl = card && card.querySelector(".rizz-card-line");
      if (lineEl) copyText(lineEl.textContent.trim());
    });
  }

  /* ---------- RIZZ-O-MATIC machine ---------- */
  var machine = section.querySelector("[data-machine]");
  var elLine = section.querySelector("[data-machine-line]");
  var elCat = section.querySelector("[data-machine-cat]");
  var elScore = section.querySelector("[data-machine-score]");
  var elFill = section.querySelector("[data-machine-fill]");
  var elCount = section.querySelector("[data-machine-count]");
  var btnPull = section.querySelector("[data-machine-pull]");
  var btnCopy = section.querySelector("[data-machine-copy]");

  var pulls = 0;
  var current = null;
  var spinTimer = null;

  function read(card) {
    return {
      text: card.querySelector(".rizz-card-line").textContent.trim(),
      cat: card.getAttribute("data-cat"),
      rizz: parseInt(card.getAttribute("data-rizz"), 10) || 0
    };
  }

  function randomLine() {
    return read(cards[Math.floor(Math.random() * cards.length)]);
  }

  function land(d) {
    current = d;
    elLine.textContent = "“" + d.text + "”";
    elCat.textContent = d.cat;
    elScore.textContent = d.rizz;
    elFill.style.width = d.rizz + "%";
    elLine.classList.remove("is-pop");
    void elLine.offsetWidth;
    elLine.classList.add("is-pop");
  }

  function pull() {
    pulls += 1;
    if (elCount) elCount.textContent = pulls;

    var choice = randomLine();

    if (reduce) { land(choice); return; }

    if (spinTimer) clearInterval(spinTimer);
    if (machine) machine.classList.add("is-spinning");

    var ticks = 0;
    spinTimer = setInterval(function () {
      var r = randomLine();
      elLine.textContent = r.text;
      elCat.textContent = r.cat;
      elScore.textContent = r.rizz;
      ticks += 1;
      if (ticks > 9) {
        clearInterval(spinTimer);
        spinTimer = null;
        if (machine) machine.classList.remove("is-spinning");
        land(choice);
      }
    }, 70);
  }

  if (btnPull) btnPull.addEventListener("click", pull);
  if (btnCopy) btnCopy.addEventListener("click", function () {
    if (!current) { showToast("Pull a line first 😉"); return; }
    copyText(current.text);
  });

  /* ---------- filter + search ---------- */
  var chips = Array.prototype.slice.call(section.querySelectorAll(".rizz-chip"));
  var search = section.querySelector(".rizz-search");
  var countEl = section.querySelector("[data-count]");
  var emptyEl = section.querySelector("[data-empty]");
  var activeFilter = "all";

  function applyFilter() {
    var term = ((search && search.value) || "").trim().toLowerCase();
    var visible = 0;
    cards.forEach(function (card) {
      var matchCat = activeFilter === "all" || card.getAttribute("data-cat") === activeFilter;
      var matchText = !term || card.textContent.toLowerCase().indexOf(term) !== -1;
      var show = matchCat && matchText;
      card.classList.toggle("rizz-hidden", !show);
      if (show) visible += 1;
    });
    if (countEl) countEl.textContent = visible + " / " + cards.length + " lines";
    if (emptyEl) emptyEl.classList.toggle("is-visible", visible === 0);
  }

  chips.forEach(function (chip) {
    chip.addEventListener("click", function () {
      activeFilter = chip.getAttribute("data-filter");
      chips.forEach(function (c) { c.classList.toggle("is-active", c === chip); });
      applyFilter();
    });
  });
  if (search) search.addEventListener("input", applyFilter);
  applyFilter();
})();
</script>
