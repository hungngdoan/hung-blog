      row.addEventListener("toggle", function () {
        if (!row.open) return;

        rows.forEach(function (other) {
          if (other !== row) other.open = false;
        });

        window.setTimeout(function () {
          row.scrollIntoView({ behavior: "smooth", block: "nearest" });
        }, 100);
      });
    });
  })();
</script>
