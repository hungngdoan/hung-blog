<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>404 ~ Hung's Journal</title>
    <link
      href="https://fonts.googleapis.com/css2?family=VT323&family=Press+Start+2P&display=swap"
      rel="stylesheet"
    />
    <!--
      Self-contained on purpose: GitHub Pages serves 404.html from any URL
      depth, so relative links to css/js would break on nested paths.
    -->
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #1a0a2e;
        color: #e0d0ff;
        font-family: "VT323", monospace;
        text-align: center;
        padding: 20px;
      }

      .lost-box {
        border: 2px solid #ff69b4;
        background: #0d0d2b;
        box-shadow: 0 0 12px rgba(255, 105, 180, 0.5);
        padding: 32px 40px;
        max-width: 480px;
      }

      h1 {
        font-family: "Press Start 2P", monospace;
        font-size: 28px;
        color: #ffd700;
        margin-bottom: 16px;
      }

      p {
        font-size: 22px;
        margin-bottom: 12px;
      }

      a {
        color: #00ccff;
        font-size: 22px;
      }

      a:hover {
        color: #00ffff;
      }
    </style>
  </head>
  <body>
    <div class="lost-box">
      <h1>404</h1>
      <p>&#128126; You wandered off the map.</p>
      <p>
        <a href="{{ site.url }}/">&gt;&gt; warp back to Hung's Journal</a>
      </p>
    </div>
  </body>
</html>
