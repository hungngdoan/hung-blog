    white-space: nowrap;
    border: 0;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 520px) {
    .taothao-page .tt-wrapper {
      --tt-card-w: min(85vw, 340px);
      --tt-card-h: min(120vw, 490px);
