  }
  @media (max-width: 360px) {
    .taothao-page .tt-wrapper { --tt-card-w: 90vw; --tt-card-h: 128vw; }
    .taothao-page .tt-arrow-btn { width: 30px; height: 30px; font-size: 0.85rem; }
    .taothao-page .tt-card-art { height: 90px; }
    .taothao-page .tt-flavor-text { font-size: 1.35rem; }
    .taothao-page .tt-ctrl-btn { font-size: 0.62rem; padding: 6px 10px; }
    .taothao-page .tt-btn-row { gap: 0.5rem; }
    .taothao-page .tt-back-ornament { width: 46px; height: 46px; }
    .taothao-page .tt-back-symbol { font-size: 0.95rem; }
  }

  /* ===== REDUCED MOTION ===== */
  @media (prefers-reduced-motion: reduce) {
    .taothao-page .tt-rune-circle,
    .taothao-page .tt-rune-circle::before,
    .taothao-page .tt-particle { animation: none; }
    .taothao-page .tt-card-flipper { transition-duration: 0.01ms; }
    .taothao-page .tt-card-flipper.transitioning { animation: none; }
  }
</style>

{% set card = taothaoCards[0] %}
{% set s1 = card.artShapes[0] %}
{% set s2 = card.artShapes[1] %}

<div class="tt-wrapper">
  <div class="tt-atmosphere" aria-hidden="true">
    <div class="tt-bg-gradient"></div>
    <div class="tt-bg-stars"></div>
    <div class="tt-rune-circle"></div>
    <div class="tt-rune-circle"></div>
    <div class="tt-rune-circle"></div>
    <div class="tt-particle"></div>
    <div class="tt-particle"></div>
    <div class="tt-particle"></div>
    <div class="tt-particle"></div>
    <div class="tt-particle"></div>
    <div class="tt-particle"></div>
    <div class="tt-particle"></div>
    <div class="tt-particle"></div>
  </div>

  <header class="tt-header">
    <h2>Tào Tháo</h2>
    <div class="tt-subtitle">Binh Pháp & Xử Thế</div>
  </header>

  <div id="ttLiveStatus" class="tt-sr-only" aria-live="polite" aria-atomic="true"></div>

  <div class="tt-stage">
    <button class="tt-arrow-btn" id="ttArrowLeft" aria-label="Thẻ trước" title="Thẻ trước">&#9664;</button>

    <div class="tt-card-area" id="ttCardArea">
      <div class="tt-deck-layer" aria-hidden="true"></div>
      <div class="tt-deck-layer" aria-hidden="true"></div>
      <div class="tt-deck-layer" aria-hidden="true"></div>

      <div class="tt-card-flipper" id="ttCardFlipper" role="button" tabindex="0"
           aria-label="{{ card.name }}. Nhấn để lật thẻ.">
        <div class="tt-card-face tt-card-front" id="ttCardFront" aria-hidden="false">
          <div class="tt-card-inner-border" aria-hidden="true"></div>
          <div class="tt-gem tt-gem-tl" aria-hidden="true">
            <div class="tt-gem-bg" id="ttGemBg0"></div>
            <span class="tt-gem-num" id="ttGemNum0">1</span>
          </div>
          <div class="tt-gem tt-gem-tr" aria-hidden="true">
            <div class="tt-gem-bg" id="ttGemBg1"></div>
            <span class="tt-gem-num" id="ttGemNum1">1</span>
          </div>

          <div class="tt-card-art" aria-hidden="true">
            <div class="tt-card-art-inner">
              <div class="tt-art-gradient" id="ttArtGradient" style="background: linear-gradient(145deg, {{ card.artColors | join(', ') }})"></div>
              <div class="tt-art-shape" id="ttArtShape1" style="background: {{ s1.bg }}; width: {{ s1.w }}px; height: {{ s1.h }}px; left: {{ s1.x }}; top: {{ s1.y }}"></div>
              <div class="tt-art-shape" id="ttArtShape2" style="background: {{ s2.bg }}; width: {{ s2.w }}px; height: {{ s2.h }}px; left: {{ s2.x }}; top: {{ s2.y }}"></div>
              <div class="tt-art-rune" id="ttArtRune">{{ card.rune }}</div>
              <div class="tt-art-vignette"></div>
            </div>
          </div>

          <div class="tt-text-box">
            <div class="tt-flavor-text" id="ttFlavorText">{{ card.flavor }}</div>
          </div>

          <div class="tt-nameplate">
            <div class="tt-card-name" id="ttCardName">{{ card.name }}</div>
          </div>
          <div class="tt-type-line" id="ttTypeLine">{{ card.type }}</div>

          <div class="tt-gem tt-gem-bl" aria-hidden="true">
            <div class="tt-gem-bg" id="ttGemBg2"></div>
            <span class="tt-gem-num" id="ttGemNum2">1</span>
          </div>
          <div class="tt-gem tt-gem-br" aria-hidden="true">
            <div class="tt-gem-bg" id="ttGemBg3"></div>
            <span class="tt-gem-num" id="ttGemNum3">1</span>
          </div>
          <div class="tt-set-symbol" id="ttSetSymbol">{{ card.set }}</div>
        </div>

        <div class="tt-card-face tt-card-back" id="ttCardBack" aria-hidden="true">
          <div class="tt-back-border-pattern" aria-hidden="true"></div>
          <div class="tt-back-corner tt-tl" aria-hidden="true"></div>
          <div class="tt-back-corner tt-tr" aria-hidden="true"></div>
          <div class="tt-back-corner tt-bl" aria-hidden="true"></div>
          <div class="tt-back-corner tt-br" aria-hidden="true"></div>
          <div class="tt-card-back-content">
            <div class="tt-back-label">Giải Nghĩa</div>
            <div class="tt-back-quote" id="ttBackQuote">{{ card.flavor }}</div>
            <div class="tt-back-explanation" id="ttBackExplanation">{{ card.ability }}</div>
            <div class="tt-back-ornament" aria-hidden="true">
              <span class="tt-back-symbol">T</span>
            </div>
            <div class="tt-back-card-name" id="ttBackCardName">{{ card.name }}</div>
          </div>
        </div>
      </div>
    </div>

    <button class="tt-arrow-btn" id="ttArrowRight" aria-label="Thẻ sau" title="Thẻ sau">&#9654;</button>
  </div>

  <nav class="tt-controls" aria-label="Điều hướng thẻ">
    <div class="tt-card-status" id="ttCardStatus">Thẻ 1 / {{ taothaoCards | length }}</div>

    <div class="tt-btn-row">
      <button class="tt-ctrl-btn" id="ttBtnPrev" aria-label="Thẻ trước">&#9664; Trước</button>
      <button class="tt-ctrl-btn tt-flip-btn" id="ttBtnFlip" aria-label="Lật thẻ">Lật Thẻ</button>
      <button class="tt-ctrl-btn" id="ttBtnNext" aria-label="Thẻ sau">Sau &#9654;</button>
    </div>

    <div class="tt-thumb-row" id="ttThumbRow" role="tablist" aria-label="Thu nhỏ thẻ">
      {%- for c in taothaoCards %}
      <button class="tt-thumb{% if loop.first %} active{% endif %}"
              role="tab"
              aria-selected="{% if loop.first %}true{% else %}false{% endif %}"
              aria-label="{{ c.name }}, thẻ {{ loop.index }}"
              tabindex="{% if loop.first %}0{% else %}-1{% endif %}"
              data-index="{{ loop.index0 }}">
        <div class="tt-thumb-art" style="background: linear-gradient(145deg, {{ c.artColors | join(', ') }})"></div>
        <div class="tt-thumb-label">{{ c.name }}</div>
        <div class="tt-thumb-index">{{ loop.index }}</div>
      </button>
      {%- endfor %}
    </div>
  </nav>
</div>

<script type="application/json" id="ttCardData">
{{ taothaoCards | dump | safe }}
</script>

<script>
(function () {
  "use strict";
  if (window.__ttCleanup) window.__ttCleanup();

  var cardArea = document.getElementById("ttCardArea");
  if (!cardArea) return;

  var dataEl = document.getElementById("ttCardData");
  if (!dataEl) return;
  var cards = JSON.parse(dataEl.textContent);

  var currentIndex = 0;
  var isFlipped = false;
  var reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  var flipper = document.getElementById("ttCardFlipper");
  var artGradient = document.getElementById("ttArtGradient");
  var artShape1 = document.getElementById("ttArtShape1");
  var artShape2 = document.getElementById("ttArtShape2");
  var artRune = document.getElementById("ttArtRune");
  var cardName = document.getElementById("ttCardName");
  var typeLine = document.getElementById("ttTypeLine");
  var flavorText = document.getElementById("ttFlavorText");
  var backQuote = document.getElementById("ttBackQuote");
  var backExplanation = document.getElementById("ttBackExplanation");
  var backCardName = document.getElementById("ttBackCardName");
  var setSymbol = document.getElementById("ttSetSymbol");
  var cardStatus = document.getElementById("ttCardStatus");
  var liveStatus = document.getElementById("ttLiveStatus");
  var thumbRow = document.getElementById("ttThumbRow");
  var cardFront = document.getElementById("ttCardFront");
  var cardBack = document.getElementById("ttCardBack");

  var gemBgs = [
    document.getElementById("ttGemBg0"),
    document.getElementById("ttGemBg1"),
    document.getElementById("ttGemBg2"),
    document.getElementById("ttGemBg3")
  ];
  var gemNums = [
    document.getElementById("ttGemNum0"),
    document.getElementById("ttGemNum1"),
    document.getElementById("ttGemNum2"),
    document.getElementById("ttGemNum3")
  ];

  var gemColors = [
    { inner: "#b8172c", outer: "#6b0f1a", glow: "rgba(184, 23, 44, 0.5)" },
    { inner: "#22c55e", outer: "#116330", glow: "rgba(34, 197, 94, 0.5)" },
    { inner: "#ff9f1c", outer: "#b36a00", glow: "rgba(255, 159, 28, 0.5)" },
    { inner: "#3a86ff", outer: "#1a4499", glow: "rgba(58, 134, 255, 0.5)" },
    { inner: "#ff69b4", outer: "#9f2a6b", glow: "rgba(255, 105, 180, 0.5)" },
    { inner: "#2af5d0", outer: "#0e7a66", glow: "rgba(42, 245, 208, 0.5)" },
    { inner: "#c9a23c", outer: "#8a6e24", glow: "rgba(201, 162, 60, 0.5)" },
    { inner: "#6a4bc3", outer: "#3a2570", glow: "rgba(106, 75, 195, 0.5)" },
    { inner: "#00ffff", outer: "#008899", glow: "rgba(0, 255, 255, 0.5)" },
    { inner: "#ff4f9f", outer: "#991b55", glow: "rgba(255, 79, 159, 0.5)" },
    { inner: "#ff8ac7", outer: "#a83272", glow: "rgba(255, 138, 199, 0.5)" },
    { inner: "#ff00cc", outer: "#8f0072", glow: "rgba(255, 0, 204, 0.5)" },
    { inner: "#d946ef", outer: "#7e1f8f", glow: "rgba(217, 70, 239, 0.5)" },
    { inner: "#7fff00", outer: "#3f8f00", glow: "rgba(127, 255, 0, 0.5)" },
    { inner: "#00ccff", outer: "#006d99", glow: "rgba(0, 204, 255, 0.5)" },
    { inner: "#e0d0ff", outer: "#8270b0", glow: "rgba(224, 208, 255, 0.5)" },
    { inner: "#9988bb", outer: "#51466f", glow: "rgba(153, 136, 187, 0.5)" },
    { inner: "#ff0000", outer: "#970000", glow: "rgba(255, 0, 0, 0.5)" },
    { inner: "#dc2626", outer: "#7f1010", glow: "rgba(220, 38, 38, 0.5)" },
    { inner: "#ff5c5c", outer: "#9e1f1f", glow: "rgba(255, 92, 92, 0.5)" },
    { inner: "#ffd700", outer: "#9a7b00", glow: "rgba(255, 215, 0, 0.5)" },
    { inner: "#ffff00", outer: "#8f8f00", glow: "rgba(255, 255, 0, 0.5)" },
    { inner: "#00ff00", outer: "#008a00", glow: "rgba(0, 255, 0, 0.5)" },
    { inner: "#49c6e5", outer: "#17667d", glow: "rgba(73, 198, 229, 0.5)" },
    { inner: "#0088ff", outer: "#004a96", glow: "rgba(0, 136, 255, 0.5)" },
    { inner: "#4f46e5", outer: "#27216f", glow: "rgba(79, 70, 229, 0.5)" },
    { inner: "#8800ff", outer: "#4d008f", glow: "rgba(136, 0, 255, 0.5)" },
    { inner: "#beaaff", outer: "#6750a4", glow: "rgba(190, 170, 255, 0.5)" },
    { inner: "#f5f7ff", outer: "#7c849f", glow: "rgba(245, 247, 255, 0.5)" },
    { inner: "#be123c", outer: "#6e0a22", glow: "rgba(190, 18, 60, 0.5)" },
    { inner: "#34d399", outer: "#167d56", glow: "rgba(52, 211, 153, 0.5)" },
    { inner: "#93c5fd", outer: "#3b5f96", glow: "rgba(147, 197, 253, 0.5)" }
  ];

  function renderCard(animate) {
    var c = cards[currentIndex];
    var num = currentIndex + 1;
    var gc = gemColors[currentIndex % gemColors.length];

    for (var g = 0; g < 4; g++) {
      gemNums[g].textContent = num;
      gemBgs[g].style.background = "radial-gradient(circle, " + gc.inner + " 30%, " + gc.outer + " 70%, #8a6e24 100%)";
      gemBgs[g].style.boxShadow = "0 0 12px " + gc.glow + ", inset 0 -2px 4px rgba(0,0,0,0.4), inset 0 2px 4px rgba(255,255,255,0.15)";
    }

    artGradient.style.background = "linear-gradient(145deg, " + c.artColors.join(", ") + ")";
    var s1 = c.artShapes[0];
    var s2 = c.artShapes[1];
    artShape1.style.cssText = "background:" + s1.bg + ";width:" + s1.w + "px;height:" + s1.h + "px;left:" + s1.x + ";top:" + s1.y + ";position:absolute;border-radius:50%;filter:blur(20px);opacity:0.6;";
    artShape2.style.cssText = "background:" + s2.bg + ";width:" + s2.w + "px;height:" + s2.h + "px;left:" + s2.x + ";top:" + s2.y + ";position:absolute;border-radius:50%;filter:blur(20px);opacity:0.6;";
    artRune.textContent = c.rune;

    cardName.textContent = c.name;
    typeLine.innerHTML = c.type;
    flavorText.textContent = c.flavor;
    backQuote.textContent = c.flavor;
    backExplanation.textContent = c.ability;
    backCardName.textContent = c.name;
    setSymbol.textContent = c.set;

    var statusText = "Thẻ " + (currentIndex + 1) + " / " + cards.length;
    cardStatus.textContent = statusText;
    liveStatus.textContent = c.name + ". " + statusText;

    var thumbs = thumbRow.querySelectorAll(".tt-thumb");
    for (var i = 0; i < thumbs.length; i++) {
      thumbs[i].classList.toggle("active", i === currentIndex);
      thumbs[i].setAttribute("aria-selected", i === currentIndex ? "true" : "false");
      thumbs[i].setAttribute("tabindex", i === currentIndex ? "0" : "-1");
    }

    flipper.setAttribute("aria-label", c.name + ". Nhấn để lật thẻ.");

    if (animate && !reducedMotion) {
      flipper.classList.add("transitioning");
      setTimeout(function () { flipper.classList.remove("transitioning"); }, 350);
    }
  }

  function flipCard() {
    isFlipped = !isFlipped;
    flipper.classList.toggle("flipped", isFlipped);
    cardFront.setAttribute("aria-hidden", isFlipped ? "true" : "false");
    cardBack.setAttribute("aria-hidden", isFlipped ? "false" : "true");
    liveStatus.textContent = isFlipped
      ? "Đã lật mặt sau."
      : "Mặt trước. " + cards[currentIndex].name;
  }

  function resetFlip() {
    if (isFlipped) {
      isFlipped = false;
      flipper.classList.remove("flipped");
      cardFront.setAttribute("aria-hidden", "false");
      cardBack.setAttribute("aria-hidden", "true");
    }
  }

  function goTo(index, animate) {
    if (index < 0) index = cards.length - 1;
    if (index >= cards.length) index = 0;
    currentIndex = index;
    resetFlip();
    renderCard(animate !== false);
  }

  function goPrev() { goTo(currentIndex - 1); }
  function goNext() { goTo(currentIndex + 1); }

  document.getElementById("ttBtnPrev").addEventListener("click", goPrev);
  document.getElementById("ttBtnNext").addEventListener("click", goNext);
  document.getElementById("ttArrowLeft").addEventListener("click", goPrev);
  document.getElementById("ttArrowRight").addEventListener("click", goNext);
  document.getElementById("ttBtnFlip").addEventListener("click", flipCard);

  flipper.addEventListener("click", flipCard);
  flipper.addEventListener("keydown", function (e) {
    if (e.key === "Enter" || e.key === " ") {
      e.preventDefault();
      flipCard();
    }
  });

  thumbRow.addEventListener("click", function (e) {
    var thumb = e.target.closest(".tt-thumb");
    if (!thumb) return;
    var idx = parseInt(thumb.getAttribute("data-index"), 10);
    if (!isNaN(idx)) goTo(idx);
  });

  function handleKeydown(e) {
    if (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA") return;
    if (!document.getElementById("ttCardArea")) return;
    if (e.key === "ArrowLeft") { e.preventDefault(); goPrev(); }
    else if (e.key === "ArrowRight") { e.preventDefault(); goNext(); }
  }
  document.addEventListener("keydown", handleKeydown);

  var touchStartX = 0;
  var touchStartY = 0;
  var touchStartTime = 0;
  var SWIPE_THRESHOLD = 40;
  var SWIPE_MAX_TIME = 400;

  function onTouchStart(e) {
    var t = e.touches[0];
    touchStartX = t.clientX;
    touchStartY = t.clientY;
    touchStartTime = Date.now();
  }
  function onTouchEnd(e) {
    var t = e.changedTouches[0];
    var dx = t.clientX - touchStartX;
    var dy = t.clientY - touchStartY;
    var elapsed = Date.now() - touchStartTime;
    if (elapsed > SWIPE_MAX_TIME) return;
    if (Math.abs(dx) < SWIPE_THRESHOLD) return;
    if (Math.abs(dy) > Math.abs(dx)) return;
    e.preventDefault();
    if (dx < 0) goNext();
    else goPrev();
  }
  cardArea.addEventListener("touchstart", onTouchStart, { passive: true });
  cardArea.addEventListener("touchend", onTouchEnd, { passive: false });

  renderCard(false);

  window.__ttCleanup = function () {
    document.removeEventListener("keydown", handleKeydown);
    cardArea.removeEventListener("touchstart", onTouchStart);
    cardArea.removeEventListener("touchend", onTouchEnd);
  };
})();
</script>
