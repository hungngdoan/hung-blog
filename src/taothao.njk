    .taothao-page .tt-arrow-btn:focus-visible { opacity: 1; transform: translateY(-50%) scale(1.08); }
    .taothao-page .tt-arrow-btn:active { transform: translateY(-50%) scale(0.95); }
    .taothao-page #ttArrowLeft { left: 4px; }
    .taothao-page #ttArrowRight { right: 4px; }
    .taothao-page .tt-card-art { height: 110px; margin: 10px 10px 0; }
    .taothao-page .tt-gem { width: 34px; height: 34px; }
    .taothao-page .tt-gem-tl { top: 6px; left: 6px; }
    .taothao-page .tt-gem-tr { top: 6px; right: 6px; }
    .taothao-page .tt-gem-bl { bottom: 6px; left: 6px; }
    .taothao-page .tt-gem-br { bottom: 6px; right: 6px; }
