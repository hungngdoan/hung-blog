      radial-gradient(1px 1px at 15% 80%, rgba(255,255,255,0.2), transparent),
      radial-gradient(1px 1px at 90% 85%, rgba(255,255,255,0.3), transparent),
      radial-gradient(1px 1px at 50% 50%, rgba(255,255,255,0.2), transparent),
