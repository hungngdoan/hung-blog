      setVar("--ps-glow-color", p.glowColor);
      setVar("--ps-particle-color", p.particleColor);

      page.querySelectorAll(".ps-ink-wash stop[data-accent]").forEach(function (stop) {
        stop.setAttribute("stop-color", p.accent);
      });

      page.querySelectorAll("[data-palette]").forEach(function (button) {
        var isActive = button.getAttribute("data-palette") === currentPalette;
        button.classList.toggle("active", isActive);
        button.setAttribute("aria-pressed", String(isActive));
      });
    }

    function applyFont(key) {
      var f = FONTS[key];
      if (!f) return;

      currentFont = key;
      setVar("--ps-heading-font", f.heading);
      setVar("--ps-heading-weight", f.headingWeight);
      setVar("--ps-heading-style", f.headingStyle);
      setVar("--ps-heading-size", f.headingSize + "px");
      setVar("--ps-body-font", f.body);
      setVar("--ps-body-size", f.bodySize + "px");
      setVar("--ps-body-weight", f.bodyWeight);
      setVar("--ps-label-font", f.labelFont);
      setVar("--ps-quote-size", f.quoteSize + "px");
      setVar("--ps-quote-weight", f.quoteWeight);
      setVar("--ps-quote-style", f.quoteStyle);
      setVar("--ps-spacing", f.spacing);

      page.querySelectorAll("[data-font]").forEach(function (button) {
        var isActive = button.getAttribute("data-font") === currentFont;
        button.classList.toggle("active", isActive);
        button.setAttribute("aria-pressed", String(isActive));
      });
    }

    function renderPaletteSwatches() {
      var grid = document.getElementById("ps-palette-grid");
      if (!grid) return;

      grid.innerHTML = "";
      Object.keys(PALETTES).forEach(function (key) {
        var p = PALETTES[key];
        var button = document.createElement("button");
        button.type = "button";
        button.className = "ps-swatch ps-palette-swatch";
        button.setAttribute("data-palette", key);
        button.setAttribute("aria-pressed", "false");
        button.style.setProperty("--swatch-bg", p.pageBg);
        button.style.setProperty("--swatch-text", p.text);
        button.style.setProperty("--swatch-muted", p.muted);

        var dots = document.createElement("div");
        dots.className = "ps-palette-dots";
        [p.accent, p.text, p.textSoft, p.cardBg].forEach(function (color, index) {
          var dot = document.createElement("span");
          dot.className = index === 3 ? "ps-palette-dot ps-palette-dot-card" : "ps-palette-dot";
          dot.style.setProperty("--dot-color", color);
          dot.style.setProperty("--dot-border", p.border);
          dots.appendChild(dot);
        });

        var name = document.createElement("div");
        name.className = "ps-swatch-name";
        name.textContent = p.name;

        var desc = document.createElement("div");
        desc.className = "ps-swatch-desc";
        desc.textContent = p.desc;

        button.appendChild(dots);
        button.appendChild(name);
        button.appendChild(desc);
        button.addEventListener("click", function () {
          applyPalette(key);
        });
        grid.appendChild(button);
      });
    }

    function renderFontSwatches() {
      var grid = document.getElementById("ps-font-grid");
      if (!grid) return;

      grid.innerHTML = "";
      Object.keys(FONTS).forEach(function (key) {
        var f = FONTS[key];
        var button = document.createElement("button");
        button.type = "button";
        button.className = "ps-swatch ps-font-swatch";
        button.setAttribute("data-font", key);
        button.setAttribute("aria-pressed", "false");

        var sample = document.createElement("div");
        sample.className = "ps-font-sample";
        sample.textContent = f.sample;
        sample.style.fontFamily = f.sampleFont;
        sample.style.fontWeight = f.headingWeight;
        sample.style.fontStyle = f.headingStyle;

        var name = document.createElement("div");
        name.className = "ps-swatch-name";
        name.textContent = f.name;

        var vibe = document.createElement("div");
        vibe.className = "ps-swatch-desc";
        vibe.textContent = f.vibe;

        button.appendChild(sample);
        button.appendChild(name);
        button.appendChild(vibe);
        button.addEventListener("click", function () {
          applyFont(key);
        });
        grid.appendChild(button);
      });
    }

    function togglePost(id) {
      expandedPostId = expandedPostId === id ? null : id;

      page.querySelectorAll(".ps-post").forEach(function (article) {
        var postId = Number(article.getAttribute("data-post-id"));
        var isExpanded = postId === expandedPostId;
        var label = article.querySelector(".ps-toggle-label");

        article.classList.toggle("expanded", isExpanded);
        article.setAttribute("aria-expanded", String(isExpanded));
        if (label) {
          label.textContent = isExpanded ? "Thu gọn" : "Đọc tiếp";
        }
      });
    }

    var posts = page.querySelector(".ps-posts");
    if (posts) {
      posts.addEventListener("click", function (event) {
        var article = event.target.closest(".ps-post");
        if (!article) return;
        togglePost(Number(article.getAttribute("data-post-id")));
      });

      posts.addEventListener("keydown", function (event) {
        if (event.key !== "Enter" && event.key !== " ") return;
        var article = event.target.closest(".ps-post");
        if (!article) return;
        event.preventDefault();
        togglePost(Number(article.getAttribute("data-post-id")));
      });
    }

    renderPaletteSwatches();
    renderFontSwatches();
    applyPalette("ink_gold");
    applyFont("bodoni");
  })();
</script>
