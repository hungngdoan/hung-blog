<style>
{% include "css/pearls.css" %}</style>

<section class="pearl-stage" aria-label="Pearl color gallery">
  <div class="pearl-grid">
    {%- for pearl in pearls %}
    <figure class="pearl-swatch" style="--gem-inner: {{ pearl.inner }}; --gem-outer: {{ pearl.outer }}; --gem-glow: {{ pearl.glow }};">
      <span class="pearl-cell" aria-hidden="true">
        <span class="tt-gem"><span class="tt-gem-bg"></span><span class="tt-gem-num"></span></span>
      </span>
      <figcaption class="pearl-label">
        <span class="pearl-name">{{ pearl.name }}</span>
        <span class="pearl-code">{{ pearl.inner }}</span>
      </figcaption>
    </figure>
    {%- endfor %}
  </div>
</section>
