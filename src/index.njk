layout: base.njk
title: "~*~ Hung's Journal ~*~"
description: "Hung's personal journal about life, fitness, code, books, games, and ideas."
navActive: index.html
showVisitorCounter: true
permalink: index.html
---

<section class="home-discovery" aria-label="Featured destinations">
  <button
    type="button"
    class="featured-thought"
    data-story-open
    data-story-key="infinite-monkey-paradox"
    data-story-url="{{ '/posts/the-infinite-monkey-paradox/' | url }}"
    aria-haspopup="dialog"
    aria-controls="story-overlay"
    aria-expanded="false"
    aria-label="Open the Infinite Monkey Paradox interactive thought experiment"
  >
    <span class="featured-thought-mark" aria-hidden="true">&#8734;</span>
    <span class="featured-thought-body">
      <span class="featured-thought-eyebrow" aria-hidden="true">Thought experiment</span>
      <span class="featured-thought-title">The Infinite Monkey Paradox</span>
    </span>
    <span class="featured-thought-action" aria-hidden="true">
      <span class="featured-thought-action-idle">PLAY <span class="featured-thought-glyph">&#9654;</span></span>
      <span class="featured-thought-action-busy">LOADING</span>
    </span>
  </button>

  <a
    href="https://hungngdoan.github.io/goc-cua-hung/"
    class="warp-zone"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Warp zone detected: open the Vietnamese portal in a new tab"
  >
    <span class="warp-zone-signal" aria-hidden="true">
      <span class="warp-zone-dot">&#9670;</span>
      <span>WARP ZONE</span>
      <span class="warp-zone-detected">DETECTED</span>
    </span>
    <span class="warp-zone-destination">Vietnamese portal</span>
    <span class="warp-zone-leader" aria-hidden="true"></span>
    <span class="warp-zone-arrow" aria-hidden="true">&#8599;</span>
  </a>
</section>

{%- for post in collections.post | reverse | limit(10) %}
{% set postTitleHtml = post.data.titleHtml %}
{% set postDisplayDate = post.data.displayDate %}
{% set postDateIso = post.data.date | isoDate %}
{% set postMoodHtml = post.data.moodHtml %}
{% set postTags = post.data.postTags %}
{% set postClass = post.data.postClass %}
{% set postUrl = post.url %}
{% set postContent = post.templateContent %}
{% set postHeadingLink = true %}
{% set showArchiveLink = false %}
{% include "partials/post-card.njk" %}
{%- endfor %}

<p class="home-archive-link">
  <a href="/archive.html">&gt;&gt; View all posts in the archive</a>
</p>

