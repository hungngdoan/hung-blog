<script>
  (function () {
    var audio = document.getElementById("musicAudio");
    var btn = document.getElementById("musicPlayBtn");
    var bar = document.getElementById("musicProgressBar");
    var wrap = document.getElementById("musicProgressWrap");
    var time = document.getElementById("musicTime");
    var vol = document.getElementById("musicVolSlider");
    var volIcon = document.getElementById("musicVolIcon");
    var prevVol = 0.5;
    var PLAY_ICON = "\u25b6";
    var PAUSE_ICON = "\u275a\u275a";
    var MUSIC_ICON = "\u266a";
    var MUTE_ICON = "\u2715";

    if (!audio || !btn || !bar || !wrap || !time || !vol || !volIcon) {
      return;
    }

    audio.volume = 0.5;

    function fmt(s) {
      var m = Math.floor(s / 60);
      var sec = Math.floor(s % 60);
      return m + ":" + (sec < 10 ? "0" : "") + sec;
    }

    function setPlaying(isPlaying) {
      btn.textContent = isPlaying ? PAUSE_ICON : PLAY_ICON;
      btn.classList.toggle("playing", isPlaying);
      btn.setAttribute("aria-label", isPlaying ? "Pause" : "Play");
      btn.title = isPlaying ? "Pause" : "Play";
    }

    function showAudioError() {
      setPlaying(false);
      btn.disabled = false;
      btn.setAttribute("aria-label", "Audio unavailable");
      btn.title = "Audio unavailable";
      time.textContent = "error";
    }

    btn.addEventListener("click", function () {
      if (audio.paused) {
        btn.disabled = true;
        btn.title = "Loading";

        var playAttempt = audio.play();
        if (playAttempt && typeof playAttempt.then === "function") {
          playAttempt
            .then(function () {
              btn.disabled = false;
              setPlaying(true);
            })
            .catch(showAudioError);
        } else {
          btn.disabled = false;
          setPlaying(true);
        }
      } else {
        audio.pause();
        setPlaying(false);
      }
    });

    audio.addEventListener("timeupdate", function () {
      if (audio.duration) {
        bar.style.width = (audio.currentTime / audio.duration) * 100 + "%";
        time.textContent = fmt(audio.currentTime);
      }
    });

    audio.addEventListener("ended", function () {
      setPlaying(false);
      bar.style.width = "0%";
      time.textContent = "0:00";
    });

    audio.addEventListener("error", showAudioError);

    wrap.addEventListener("click", function (e) {
      if (audio.duration) {
        var rect = wrap.getBoundingClientRect();
        audio.currentTime =
          ((e.clientX - rect.left) / rect.width) * audio.duration;
      }
    });

    vol.addEventListener("input", function () {
      audio.volume = vol.value / 100;
      volIcon.textContent = audio.volume === 0 ? MUTE_ICON : MUSIC_ICON;
    });

    volIcon.addEventListener("click", function () {
      if (audio.volume > 0) {
        prevVol = audio.volume;
        audio.volume = 0;
        vol.value = 0;
        volIcon.textContent = MUTE_ICON;
      } else {
        audio.volume = prevVol;
        vol.value = prevVol * 100;
        volIcon.textContent = MUSIC_ICON;
      }
    });
  })();
</script>
