<div
  id="story-overlay"
  class="story-overlay"
  role="dialog"
  aria-modal="true"
  aria-labelledby="story-title"
  hidden
>
  <div class="story-shell" tabindex="-1" data-story-shell data-tone="origin">
    <header class="story-header">
      <div class="story-identity">
        <span class="story-signal" aria-hidden="true">&#8734;</span>
        <div>
          <span class="story-eyebrow">THOUGHT EXPERIMENT</span>
          <h2 id="story-title">Story Mode</h2>
        </div>
      </div>
      <button
        type="button"
        class="story-close"
        data-story-close
        aria-label="Close story"
        title="Close story"
      >
        &#10005;
      </button>
    </header>

    <div class="story-progress-row">
      <div
        class="story-progress-track"
        role="progressbar"
        aria-label="Story progress"
        aria-valuemin="1"
        aria-valuemax="1"
        aria-valuenow="1"
        data-story-progress-track
      >
        <span data-story-progress></span>
      </div>
      <span class="story-count" data-story-count>01 / 01</span>
    </div>

    <main class="story-stage" data-story-stage aria-live="polite"></main>

    <footer class="story-controls">
      <button type="button" class="story-control story-control-back" data-story-prev>
        <span aria-hidden="true">&#9664;</span> Back
      </button>
      <span class="story-key-hint" aria-hidden="true">Use &larr; &rarr; or Space</span>
      <button type="button" class="story-control story-control-next" data-story-next>
        Next <span aria-hidden="true">&#9654;</span>
      </button>
    </footer>
  </div>
</div>

