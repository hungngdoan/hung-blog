<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script>
      /* Marks a JS-capable browser before first paint. JS-only controls
         (story launchers) are hidden without it, so no-JS visitors never
         see a button that cannot work. */
      document.documentElement.classList.add("js");
    </script>
    <title>{% if isPost %}{{ title }} ~ Hung's Journal{% else %}{{ title or site.title }}{% endif %}</title>
    <meta name="description" content="{{ description or site.description }}" />
    <meta property="og:title" content="{{ title or site.title }}" />
    <meta property="og:description" content="{{ description or site.description }}" />
    <meta property="og:type" content="{{ 'article' if isPost else 'website' }}" />
    <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
    <meta property="og:image" content="{{ site.url }}{{ site.shareCardSrc }}" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="{{ site.shareCardAlt }}" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#1a0a2e" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
    <link
      data-page-fonts
      href="{{ fontsUrl if fontsUrl else site.defaultFontsUrl }}"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
    <script src="/js/site.js" defer></script>
  </head>
  <body class="{% if navActive == 'index.html' %}is-home{% else %}is-inner{% endif %}{% if showVisitorCounter %} has-counter{% endif %}">
    {% include "partials/marquee.njk" %}
    <div class="page-wrapper">
      {% include "partials/header.njk" %}
      {% include "partials/nav.njk" %}
      <div class="content-grid">
        {% include "partials/sidebar.njk" %}
        <main class="main-content{% if pageClass %} {{ pageClass }}{% endif %}">
          {{ content | safe }}
        </main>
      </div>
      {% include "partials/footer.njk" %}
    </div>
    <div class="scroll-jump-controls" aria-label="Page scroll controls">
      <button
        type="button"
        class="scroll-jump-button"
        data-to-top
        aria-label="Back to top"
        aria-disabled="true"
        disabled
        title="Back to top"
      >
        &#9650;
      </button>
      <button
        type="button"
        class="scroll-jump-button"
        data-to-bottom
        aria-label="Go to bottom"
        aria-disabled="true"
        disabled
        title="Go to bottom"
      >
        &#9660;
      </button>
    </div>
    <button
      type="button"
      id="rp-fab"
      class="rp-fab"
      aria-haspopup="dialog"
      aria-controls="rp-overlay"
      aria-label="Open a random post"
      title="Random post"
      data-rp-index="{{ '/random-index.json' | url }}"
    >
      <span class="rp-fab-die" aria-hidden="true">&#127922;</span>
      <span class="rp-fab-label" aria-hidden="true">RANDOM POST</span>
    </button>

    <div
      id="rp-overlay"
      class="rp-overlay"
      role="dialog"
      aria-modal="true"
      aria-labelledby="rp-title"
      hidden
    >
      <div class="rp-modal" tabindex="-1" data-rp-modal>
        <div class="rp-modal-bar" aria-hidden="true"></div>
        <header class="rp-head">
          <span class="rp-head-spark" aria-hidden="true">&#9876;</span>
          <h2 id="rp-title" class="rp-head-title">A WILD POST APPEARED!</h2>
          <span class="rp-head-spark" aria-hidden="true">&#9876;</span>
          <span class="rp-draw-chip" data-rp-counter>DRAW #1</span>
        </header>
        <div class="rp-stage" data-rp-stage></div>
        <footer class="rp-foot">
          <button type="button" class="rp-btn rp-btn-reroll" data-rp-reroll>
            <span aria-hidden="true">&#127922;</span> ENCOUNTER AGAIN
          </button>
          <button type="button" class="rp-btn rp-btn-flee" data-rp-close>
            FLEE <span class="rp-key" aria-hidden="true">ESC</span>
          </button>
        </footer>
      </div>
    </div>

    {% include "partials/story-player.njk" %}
    {% include "partials/music-player-script.njk" %}
    <script src="/js/page-transitions.js" defer></script>
    <script src="/js/random-post.js" defer></script>
    <script src="/js/story-player.js" defer></script>
  </body>
</html>
