---
layout: base.njk
title: "Raymond Reddington Quotes ~ Hung's Journal"
navActive: reddington.html
permalink: reddington.html
pageClass: reddington-page
---

<style>
{% include "css/reddington.css" %}</style>

<section class="page-section quotes-section">
  <h2>Raymond Reddington Quotes</h2>
  <p>A cleaned collection of sharp, strategic, and dangerous lines from Raymond "Red" Reddington.</p>
  <p>Origin: Raymond "Red" Reddington from The Blacklist TV series.</p>

  <div class="reddington-tools">
    <label class="reddington-sr-only" for="reddingtonSearch">Search Raymond Reddington quotes</label>
    <input
      class="reddington-search"
      id="reddingtonSearch"
      type="search"
      autocomplete="off"
      placeholder="Search quotes"
    />
    <div class="reddington-count" id="reddingtonCount">{{ reddingtonQuotes | length }} quotes</div>
  </div>

  <div class="quote-list" id="reddingtonList" aria-label="Raymond Reddington quotes">
    {%- for quote in reddingtonQuotes %}
    <blockquote class="quote-item reddington-quote" data-quote="{{ quote | lower }}">
      <p><span class="reddington-index">{{ loop.index }}.</span> "{{ quote }}"</p>
    </blockquote>
    {%- endfor %}
  </div>

  <p class="reddington-empty" id="reddingtonEmpty">No quotes found.</p>
</section>

{# Source for the random-post die: on this page the die draws a Reddington
   quote instead of a blog post. Inert <template>, rendered once. #}
<template data-rp-source data-rp-title="A WILD QUOTE APPEARED!">
  {%- for quote in reddingtonQuotes %}
  <article class="blog-post">
    <div class="post-header">
      <span class="post-title">&#128213; Reddington Intel</span>
      <span class="post-date">No. {{ loop.index }}</span>
    </div>
    <div class="post-body">
      <p><span class="post-opener">"{{ quote }}"</span></p>
    </div>
    <div class="post-mood">&#9670; Raymond "Red" Reddington &#183; The Blacklist</div>
  </article>
  {%- endfor %}
</template>

<script>
(function () {
  "use strict";

  var input = document.getElementById("reddingtonSearch");
  var count = document.getElementById("reddingtonCount");
  var empty = document.getElementById("reddingtonEmpty");
  var quotes = Array.prototype.slice.call(document.querySelectorAll(".reddington-quote"));

  if (!input || !count || !empty || !quotes.length) return;

  function filterQuotes() {
    var term = input.value.trim().toLowerCase();
    var visible = 0;

    quotes.forEach(function (quote) {
      var match = !term || quote.getAttribute("data-quote").indexOf(term) !== -1;
      quote.classList.toggle("hidden", !match);
      if (match) visible += 1;
    });

    count.textContent = visible + " / " + quotes.length + " quotes";
    empty.classList.toggle("visible", visible === 0);
  }

  input.addEventListener("input", filterQuotes);
  filterQuotes();
})();
</script>
